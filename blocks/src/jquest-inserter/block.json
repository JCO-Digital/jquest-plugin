{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "jquest-inserter/jquest-inserter",
  "version": "0.1.0",
  "title": "jQuest",
  "category": "embed",
  "icon": "games",
  "description": "Insert jQuest content.",
  "keywords": [
    "jquest",
    "game",
    "gamification",
    "learning",
    "education",
    "quiz",
    "questionnaire",
    "quizzes",
    "learn",
    "rating",
    "poll",
    "survey",
    "chooser",
    "wheel of fortune"
  ],
  "example": {},
  "supports": {
    "html": false
  },
  "textdomain": "jquest-inserter",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "attributes": {
    "selectedGame": {
      "type": "string"
    },
    "organization": {
      "type": "string"
    },
    "newStyles": {
      "type": "boolean",
      "default": true
    },
    "staging": {
      "type": "boolean",
      "default": true
    }
  }
}
