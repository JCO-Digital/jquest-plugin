{
  "name": "jcodigital/jquest-plugin",
  "description": "JQUEST Plugin",
  "type": "wordpress-plugin",
  "autoload": {
    "psr-4": {
      "jQuestPlugin\\": "classes/"
    }
  },
  "authors": [
    {
      "name": "J&Co Digital",
      "email": "support@jco.fi"
    },
    {
      "name": "Johan Österberg",
      "email": "johan@jco.fi"
    }
  ],
  "scripts": {
    "strauss": [
      "vendor/bin/strauss"
    ],
    "post-install-cmd": [
      "@strauss"
    ],
    "post-update-cmd": [
      "@strauss"
    ]
  },
  "require": {
    "stellarwp/db": "^1.0",
    "league/commonmark": "^2.4.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "brianhenryie/strauss": "^0.14.0"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
