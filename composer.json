  "require": {},
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3.6.0",
    "wp-coding-standards/wpcs": "3.1.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0.0"
