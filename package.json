{
  "name": "jquest-plugin",
  "version": "1.6.1",
  "main": "Gruntfile.js",
  "author": "J&Co Digital <maxemilian@jco.fi>",
  "scripts": {
    "start": "grunt default",
    "readme": "grunt readme",
    "i18n": "grunt i18n",
    "start-blocks": "wp-scripts start --webpack-src-dir=blocks/src --output-path=blocks/build",
    "build-blocks": "wp-scripts build --webpack-src-dir=blocks/src --output-path=blocks/build",
    "lint:js": "wp-scripts lint-js blocks/src",
    "lint:php": "./vendor/bin/phpcs",
    "check": "pnpm run lint:js && pnpm run lint:php && composer validate --strict",
    "wp:start": "wp-playground-cli start --php=8.2 --port=8881 --blueprint=.wp/latest-debug.json",
    "wp:stop": "fuser -k 8881/tcp || true",
    "wp:reset": "wp-playground-cli start --php=8.2 --port=8881 --reset --blueprint=.wp/latest-debug.json"
  },
  "devDependencies": {
    "@wordpress/scripts": "^26.19.0",
    "@wp-playground/cli": "^3.1.39",
    "grunt": "~1.6.1",
    "grunt-wp-i18n": "~1.0.3",
    "grunt-wp-readme-to-markdown": "~2.1.0",
    "prettier": "^3.3.0"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
