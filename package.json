{
  "name": "jquest-plugin",
  "version": "0.4.7",
  "main": "Gruntfile.js",
  "author": "J&Co Digital <maxemilian@jco.fi>",
  "scripts": {
    "start": "grunt default",
    "readme": "grunt readme",
    "i18n": "grunt i18n",
    "start-blocks": "wp-scripts start --webpack-src-dir=blocks/src --output-path=blocks/build",
    "build-blocks": "wp-scripts build --webpack-src-dir=blocks/src --output-path=blocks/build",
    "version": "node versionSync.mjs && pnpm start && git add -A",
    "postversion": "git push && git push --tags",
    "wp:start": "pnpm dlx @wp-now/wp-now start --php=8.2 --blueprint=.wp/latest-debug.json",
    "wp:reset": "pnpm dlx @wp-now/wp-now start --php=8.2 --reset --blueprint=.wp/latest-debug.json"
  },
  "devDependencies": {
    "grunt": "~1.6.1",
    "grunt-wp-i18n": "~1.0.3",
    "grunt-wp-readme-to-markdown": "~2.1.0",
    "@wordpress/scripts": "^26.19.0",
    "prettier": "^3.3.0"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
